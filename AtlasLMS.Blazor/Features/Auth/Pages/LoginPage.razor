@page "/login"
@inject IAuthService AuthService

<AtlasAuthForm ButtonCaption="Iniciar Sesión" User=@loginUser OnSubmit=@HandleLogin CurrentPost=@currentPost />

@code {
    private LoginDto? loginUser = new();
    private bool currentPost;

    private async Task HandleLogin()
    {
        if (loginUser is null) return;
        currentPost = true;

        Console.WriteLine($"Iniciando sesión......");

        var result = await AuthService.LoginAsync(loginUser);

        if (AtlasHelper.IsStringEmpty(result!.Token)) return;

        Console.WriteLine(result.Token);

        currentPost = false;
    }
}
