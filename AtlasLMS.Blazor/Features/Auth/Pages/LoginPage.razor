@page "/login"
@inject NavigationManager Navigation

<div class="container-fluid login-page">
    <div class="row h-100">
        <AtlasHeader/>

        <div class="col-md-6 d-flex justify-content-center align-items-center bg-light">
            <EditForm class="card shadow-lg p-4" style="width: 350px;">
                <h3 class="text-center mb-4 text-primary">Bienvenido a AtlasLMS</h3>

                <div class="mb-3">
                    <label for="username" class="form-label">Usuario</label>
                    <input type="text" id="username" class="form-control" placeholder="Usuario" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Contraseña</label>
                    <input type="password" id="password" class="form-control" placeholder="Contraseña" />
                    <div class="text-end mt-1">
                        <a href="#" class="text-decoration-none text-primary small">¿Olvidaste tu contraseña?</a>
                    </div>
                </div>

                <button class="btn btn-primary w-100">Iniciar Sesión</button>

                <footer class="text-center mt-3 text-muted small">
                    © 2026 AtlasLMS - Software de Gestión de Librerías
                </footer>
            </EditForm>
        </div>
    </div>
</div>
